    "@progress/kendo-theme-default": "^13.0.1",
    "angular-oauth2-oidc": "20.0.2",
    "apollo-angular": "13.0.0",
    "cron-parser": "5.5.0",
    "cronstrue": "3.13.0",
    "date-fns": "4.1.0",
    "flag-icons": "7.5.0",
    "graphql": "16.13.0",
    "rxjs": "7.8.2",
