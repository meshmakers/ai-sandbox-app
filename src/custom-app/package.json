{
  "name": "custom-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "setup-license": "node scripts/setup-license.js",
    "prestart": "npm run setup-license",
    "start": "ng serve",
    "build": "npm run lint && ng build",
    "prebuild:prod": "npm run setup-license",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --configuration ci",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "codegen": "graphql-codegen --config codegen.yml",
    "postinstall": "node src/environments/version.ts",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.0",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.2.0",
    "@angular/core": "21.2.0",
    "@angular/forms": "21.2.0",
    "@angular/localize": "21.2.0",
    "@angular/platform-browser": "21.2.0",
    "@angular/platform-browser-dynamic": "21.2.0",
    "@angular/router": "21.2.0",
    "@apollo/client": "4.1.6",
    "@meshmakers/octo-services": "*",
    "@meshmakers/octo-ui": "*",
    "@meshmakers/shared-auth": "*",
    "@meshmakers/shared-services": "*",
    "@meshmakers/shared-ui": "*",
    "@ngx-translate/core": "17.0.0",
    "@progress/kendo-angular-buttons": "23.2.0",
    "@progress/kendo-angular-common": "23.2.0",
    "@progress/kendo-angular-dialog": "23.2.0",
    "@progress/kendo-angular-dropdowns": "23.2.0",
    "@progress/kendo-angular-grid": "23.2.0",
    "@progress/kendo-angular-icons": "23.2.0",
    "@progress/kendo-angular-indicators": "23.2.0",
    "@progress/kendo-angular-inputs": "23.2.0",
    "@progress/kendo-angular-intl": "23.2.0",
    "@progress/kendo-angular-l10n": "23.2.0",
    "@progress/kendo-angular-label": "23.2.0",
    "@progress/kendo-angular-layout": "23.2.0",
    "@progress/kendo-angular-menu": "23.2.0",
    "@progress/kendo-angular-navigation": "23.2.0",
    "@progress/kendo-angular-notification": "23.2.0",
    "@progress/kendo-angular-popup": "23.2.0",
    "@progress/kendo-angular-progressbar": "23.2.0",
    "@progress/kendo-angular-toolbar": "23.2.0",
    "@progress/kendo-angular-tooltip": "23.2.0",
